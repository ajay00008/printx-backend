# ══════════════════════════════════════════════════════════════
# Printx.ai Node.js Backend — copy to .env and fill values
# ══════════════════════════════════════════════════════════════

PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/printxai

# STT Model server (Parakeet 600M / NeMo)
MODEL_SERVER_URL=ws://15.207.199.235:8001/infer
MODEL_SERVER_TOKEN=123

# OpenAI (for file transcription + AI post-processing)
OPENAI_API_KEY=

# Gemini (for AI summary / keypoints / action items)
GEMINI_API_KEY=

# Public base URL (used in share links)
PRINTX_BASE_URL=https://printx-ai.in

# CORS — comma-separated allowed origins (* for all)
CORS_ORIGINS=*

# Debug
LOG_LEVEL=info
